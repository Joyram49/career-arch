# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000/api/v1

# ─────────────────────────────────────────────
# CORS (comma-separated list of allowed origins)
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/careerarch_db

# For tests — uses separate DB + Redis DB 1
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/careerarch_db
TEST_REDIS_URL=redis://localhost:6379/1

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT — MUST be at least 32 chars each
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-super-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-super-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_EXPIRY_REMEMBER_ME=30d

# ─────────────────────────────────────────────
# BCRYPT
# ─────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────
# EMAIL (BREVO SMTP)
# ─────────────────────────────────────────────
BREVO_SMTP_KEY=
BREVO_SMTP_USER=
MAIL_FROM_ADDRESS=joyram2020@gmail.com
MAIL_FROM_NAME=CareerArch

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
